pipeline {
    agent any

    environment {
        IMAGE_NAME = 'myweb-app'
        IMAGE_TAG = 'latest'
    }

    stages {
        stage('Git Checkout') {
            steps {
                git url: 'https://github.com/Balaji2795/jenkins-java-project.git', branch: 'master'
            }
        }

        stage('Maven Build') {
            steps {
                sh 'mvn clean package'
            }
        }

      

     
    }
}
